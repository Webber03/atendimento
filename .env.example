# Variáveis para configurar no painel da VPS (Coolify, etc.) — NÃO commitar .env

# Opção 1: URL completa (Coolify gera ao vincular o PostgreSQL ao app)
# DATABASE_URL=postgres://usuario:senha@ic-postgresql-ZJ9c:5432/postgres

# Opção 2: variáveis separadas (rede interna da VPS)
DB_HOST=ic-postgresql-ZJ9c
DB_PORT=5432
DB_USER=user_yrXshF
DB_PASSWORD=sua_senha_aqui
DB_NAME=postgres

# Porta HTTP do app (Coolify costuma definir PORT automaticamente)
PORT=3000

# Use "true" só no primeiro deploy para zerar/recriar tabelas; depois mude para "false"
DB_RESET=true

DB_SSL=false
